{
  "name": "advance-crowdfunding-integrated",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "node": "hardhat node",
    "clear": "rm -rf node_modules package-lock.json cache",
    "deploy-local": "hardhat run scripts/deploy.js --network localhost",
    "deploy-holesky": "hardhat run scripts/deploy.js --network holesky",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "deploy:milestone:local": "npx hardhat run scripts/deployMilestone.js --network hardhat",
    "deploy:milestone:sepolia": "npx hardhat run scripts/deployMilestone.js --network sepolia",
    "migrate:sample": "npx hardhat run scripts/migrateSampleCampaign.js --network hardhat",
    "slither": "slither contracts/MilestoneManager.sol --solc-remaps @openzeppelin=$(pwd)/node_modules/@openzeppelin"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.8.2",
    "dotenv": "^16.0.3",
    "ethers": "^5.7.2",
    "hardhat": "^2.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.5",
    "chai": "^4.3.7",
    "ethereum-waffle": "^3.4.4"
  }
}
