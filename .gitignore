# =============================================================================
# CROWDFUND PRO — .gitignore
# Covers: Next.js frontend + Hardhat contracts + Oracle service + Indexer
# =============================================================================


# =============================================================================
# !! SECRETS — NEVER COMMIT THESE !!
# =============================================================================
.env
.env.*
web3/.env
oracle-service/.env
indexer/.env


# =============================================================================
# NODE MODULES — all layers
# =============================================================================
node_modules/
web3/node_modules/
oracle-service/node_modules/
indexer/node_modules/


# =============================================================================
# HARDHAT BUILD ARTIFACTS — fully regenerated on every compile + deploy
# Never commit these; they contain absolute machine paths inside .dbg.json
# and build-info/ hashes change on every compilation even with no code changes.
# =============================================================================
web3/artifacts/
web3/cache/
web3/typechain/
web3/typechain-types/


# =============================================================================
# NEXT.JS BUILD OUTPUT
# =============================================================================
.next/
out/
build/


# =============================================================================
# TEST COVERAGE OUTPUT
# =============================================================================
coverage/
coverage.json
lcov.info


# =============================================================================
# LOCK FILES — keep root package-lock.json for reproducible frontend deploys.
# Ignore sub-project lock files (Hardhat + oracle run locally).
# =============================================================================
web3/package-lock.json
oracle-service/package-lock.json


# =============================================================================
# OS / EDITOR JUNK
# =============================================================================
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json
*.swp
*.swo
*~


# =============================================================================
# LOGS
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log


# =============================================================================
# VERCEL / DEPLOYMENT
# =============================================================================
.vercel


# =============================================================================
# MISC
# =============================================================================
.pnp
.pnp.js
